# =============================================================================
# Pabawi v1.0.0 — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All integration configuration is loaded from this file at startup.
# Restart the application after making changes.
# =============================================================================

# Application
PORT=3000
HOST=localhost
LOG_LEVEL=info
AUTH_MODE=local
# Upstream proxy auth headers (used when AUTH_MODE=proxy)
# Header names are case-insensitive in HTTP; configure the canonical names here.
AUTH_PROXY_USER_HEADER=x-forwarded-user
# AUTH_PROXY_EMAIL_HEADER=x-forwarded-email
# AUTH_PROXY_GROUPS_HEADER=x-forwarded-groups

# JWT Secret for authentication (REQUIRED - generate a secure random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secure-random-secret-here # pragma: allowlist secret

# Database Path
DATABASE_PATH=./data/pabawi.db

# CORS (comma-separated origins; defaults to localhost dev ports)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Allowed commands
COMMAND_WHITELIST_ALLOW_ALL=false
COMMAND_WHITELIST=["ls","pwd","whoami","id","hostname","uname -a","uptime","w","cat","head","tail","grep","df -h","du -sh","free -h","lsblk","ps aux","ps -ef","top -bn1","vmstat","ip a","ip r","ss -tulpn","systemctl status","journalctl -u","journalctl -n","facter","puppet facts","date","timedatectl","env","cat /etc/os-release","cat /etc/hosts","lscpu","sestatus","getenforce"]
COMMAND_WHITELIST_MATCH_MODE=prefix

# Provisioning safety
# Set to true to allow destructive provisioning actions
# (e.g., Proxmox VM/LXC destroy, AWS EC2 terminate)
ALLOW_DESTRUCTIVE_PROVISIONING=false

# UI settings
# UI_SHOW_HOME_PAGE_RUN_CHART=true

# -----------------------------------------------------------------------------
# Bolt integration (optional)
# -----------------------------------------------------------------------------
BOLT_PROJECT_PATH=./samples/integrations/bolt
BOLT_EXECUTION_TIMEOUT=300000
# Package task definitions (JSON array, see docs for format)
# BOLT_PACKAGE_TASKS=

# -----------------------------------------------------------------------------
# Ansible integration (optional)
# -----------------------------------------------------------------------------
ANSIBLE_ENABLED=false
ANSIBLE_PROJECT_PATH=./samples/integrations/ansible/
ANSIBLE_INVENTORY_PATH=inventory/hosts.yml
ANSIBLE_EXECUTION_TIMEOUT=300000
# Override the default remote user for Ansible ad-hoc inventory
# Falls back to SSH_DEFAULT_USER, then "root"
# ANSIBLE_REMOTE_USER=

# -----------------------------------------------------------------------------
# PuppetDB integration (optional)
# -----------------------------------------------------------------------------
PUPPETDB_ENABLED=false
PUPPETDB_SERVER_URL=https://puppet.example.com
PUPPETDB_PORT=8081
PUPPETDB_TOKEN=
PUPPETDB_SSL_ENABLED=false
PUPPETDB_SSL_CA=/etc/puppetlabs/puppet/ssl/certs/ca.pem
PUPPETDB_SSL_CERT=/etc/puppetlabs/puppet/ssl/certs/$(hostname).pem
PUPPETDB_SSL_KEY=/etc/puppetlabs/puppet/ssl/private_keys/$(hostname).pem
# PUPPETDB_SSL_REJECT_UNAUTHORIZED=true
# PUPPETDB_TIMEOUT=30000
# PUPPETDB_RETRY_ATTEMPTS=3
# PUPPETDB_RETRY_DELAY=1000
# PUPPETDB_CACHE_TTL=300000
# PUPPETDB_CIRCUIT_BREAKER_THRESHOLD=5
# PUPPETDB_CIRCUIT_BREAKER_TIMEOUT=60000
# PUPPETDB_CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Puppetserver integration (optional)
# -----------------------------------------------------------------------------
PUPPETSERVER_ENABLED=false
PUPPETSERVER_SERVER_URL=https://puppet.example.com
PUPPETSERVER_PORT=8140
PUPPETSERVER_TOKEN=
PUPPETSERVER_SSL_ENABLED=false
PUPPETSERVER_SSL_CA=/etc/puppetlabs/puppet/ssl/certs/ca.pem
PUPPETSERVER_SSL_CERT=/etc/puppetlabs/puppet/ssl/certs/$(hostname).pem
PUPPETSERVER_SSL_KEY=/etc/puppetlabs/puppet/ssl/private_keys/$(hostname).pem
# PUPPETSERVER_SSL_REJECT_UNAUTHORIZED=true
# PUPPETSERVER_TIMEOUT=30000
# PUPPETSERVER_RETRY_ATTEMPTS=3
# PUPPETSERVER_RETRY_DELAY=1000
# PUPPETSERVER_INACTIVITY_THRESHOLD=3600
# PUPPETSERVER_CACHE_TTL=300000
# PUPPETSERVER_CIRCUIT_BREAKER_THRESHOLD=5
# PUPPETSERVER_CIRCUIT_BREAKER_TIMEOUT=60000
# PUPPETSERVER_CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Hiera integration (optional)
# -----------------------------------------------------------------------------
HIERA_ENABLED=false
HIERA_CONTROL_REPO_PATH=./samples/integrations/puppet/
HIERA_CONFIG_PATH=hiera.yaml
# HIERA_ENVIRONMENTS=["production","staging"]
# HIERA_FACT_SOURCE_PREFER_PUPPETDB=true
# HIERA_FACT_SOURCE_LOCAL_PATH=
# HIERA_CATALOG_COMPILATION_ENABLED=false
# HIERA_CATALOG_COMPILATION_TIMEOUT=60000
# HIERA_CATALOG_COMPILATION_CACHE_TTL=300000
# HIERA_CACHE_ENABLED=true
# HIERA_CACHE_TTL=300000
# HIERA_CACHE_MAX_ENTRIES=10000
# HIERA_CODE_ANALYSIS_ENABLED=true
# HIERA_CODE_ANALYSIS_LINT_ENABLED=true
# HIERA_CODE_ANALYSIS_MODULE_UPDATE_CHECK=true
# HIERA_CODE_ANALYSIS_INTERVAL=3600000
# HIERA_CODE_ANALYSIS_EXCLUSION_PATTERNS=[]

# -----------------------------------------------------------------------------
# SSH integration (optional)
# -----------------------------------------------------------------------------
SSH_ENABLED=false
SSH_CONFIG_PATH=~/.ssh/config
SSH_DEFAULT_USER=root
SSH_DEFAULT_PORT=22
SSH_DEFAULT_KEY=
SSH_HOST_KEY_CHECK=true
SSH_CONNECTION_TIMEOUT=30
SSH_COMMAND_TIMEOUT=300
SSH_MAX_CONNECTIONS=50
SSH_MAX_CONNECTIONS_PER_HOST=5
SSH_IDLE_TIMEOUT=300
SSH_CONCURRENCY_LIMIT=10
SSH_SUDO_ENABLED=false
SSH_SUDO_COMMAND=sudo
SSH_SUDO_PASSWORDLESS=true
SSH_SUDO_PASSWORD= # pragma: allowlist secret
SSH_SUDO_USER=root
SSH_PRIORITY=50

# -----------------------------------------------------------------------------
# Proxmox integration (optional)
# -----------------------------------------------------------------------------
PROXMOX_ENABLED=false
PROXMOX_HOST=proxmox.example.com
PROXMOX_PORT=8006
# Token authentication (recommended)
# Format: user@realm!tokenid=token-value
# PROXMOX_TOKEN=user@pam!mytoken=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Username/password authentication (alternative to token)
# PROXMOX_USERNAME=root
# PROXMOX_PASSWORD= # pragma: allowlist secret
# PROXMOX_REALM=pam
PROXMOX_SSL_REJECT_UNAUTHORIZED=true
# PROXMOX_SSL_CA=
# PROXMOX_SSL_CERT=
# PROXMOX_SSL_KEY=
# PROXMOX_TIMEOUT=30000
# PROXMOX_PRIORITY=7

# -----------------------------------------------------------------------------
# AWS integration (optional)
# -----------------------------------------------------------------------------
AWS_ENABLED=false
# Use AWS profiles or IAM roles when possible instead of static keys.
# If omitted, the AWS SDK default credential chain is used
# (env vars, ~/.aws/credentials, instance profile, etc.)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY= # pragma: allowlist secret
# AWS_DEFAULT_REGION=us-east-1
# Query multiple regions (JSON array or comma-separated)
# AWS_REGIONS=["us-east-1","eu-west-1"]
# AWS_PROFILE=default
# Temporary session token (for STS/assumed roles)
# AWS_SESSION_TOKEN=
# Custom endpoint (for LocalStack or other S3-compatible services)
# AWS_ENDPOINT=

# -----------------------------------------------------------------------------
# Advanced: Streaming, caching, and execution queue
# -----------------------------------------------------------------------------
# STREAMING_BUFFER_MS=100
# STREAMING_MAX_OUTPUT_SIZE=10485760
# STREAMING_MAX_LINE_LENGTH=10000
# CACHE_INVENTORY_TTL=30000
# CACHE_FACTS_TTL=300000
# CONCURRENT_EXECUTION_LIMIT=5
# MAX_QUEUE_SIZE=50

# -----------------------------------------------------------------------------
# Advanced: Lifecycle token for inventory webhook endpoint
# -----------------------------------------------------------------------------
# PABAWI_LIFECYCLE_TOKEN=
